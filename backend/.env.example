# --- Runtime ---
# Set to "production" on Railway. Controls CORS loopback fallback and error verbosity.
NODE_ENV=production

# Railway injects PORT automatically. The fallback (4000) is for local dev only.
PORT=4000

# Comma-separated list of allowed frontend origins (no trailing slashes).
# In production: replace with your actual Vercel deployment URL.
# In development: add http://localhost:5173
CLIENT_ORIGIN=https://your-frontend.vercel.app

# --- Database ---
# On Railway: copy these from the MySQL plugin's "Connect" tab.
DB_HOST=your-mysql.railway.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_railway_mysql_password
DB_NAME=mbciansappointizen
DB_CONNECTION_LIMIT=10

# --- App ---
APP_TIMEZONE=Asia/Manila

# Required when deployed behind Railway's reverse proxy.
# Ensures rate limiting reads the real client IP, not the proxy IP.
TRUST_PROXY=1

# --- Auth ---
# CRITICAL: generate a strong secret for production.
# Run: node -e "require('crypto').randomBytes(32).toString('hex')" | pbcopy
JWT_SECRET=replace_this_with_a_long_random_hex_secret
JWT_EXPIRES_IN=7d

# --- Email / SMTP ---
# Gmail testing: use a Gmail address plus a Google App Password.
# Google account must have 2-Step Verification enabled before App Password works.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=brendonflores28@gmail.com
SMTP_PASSWORD=hpmnmspxugylzvrb
SMTP_FROM_NAME=MBCIANS Appointment System
SMTP_FROM_EMAIL=brendonflores28@gmail.com
SMTP_TEST_TO=brendonflores28@gmail.com
