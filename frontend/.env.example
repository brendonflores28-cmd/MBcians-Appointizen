# --- API URL ---
# DEVELOPMENT: Use /api (relative). Vite proxies this to VITE_DEV_PROXY_TARGET.
# PRODUCTION (Vercel): Must be the full Railway backend URL ending in /api.
#   The socket URL is automatically derived from this by stripping /api.
#   Set this in Vercel project settings → Environment Variables.
#
# Development value:
# VITE_API_URL=/api
#
# Production value:
VITE_API_URL=https://your-backend.up.railway.app/api

# --- Socket URL ---
# Leave empty. The socket URL is derived automatically from VITE_API_URL
# (strips /api suffix). Only set this if your socket server is on a
# different domain than your API.
VITE_SOCKET_URL=

# --- Dev proxy ---
# Used only by vite.config.js during local development. Not needed on Vercel.
VITE_DEV_PROXY_TARGET=http://127.0.0.1:4000

# --- Timezone ---
VITE_APP_TIMEZONE=Asia/Manila
